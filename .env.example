# Public example only. Do not put real secrets in this file.

# Web / retrieval mode
RAG_DISABLE_PGVECTOR=true
RAG_EMBEDDING_PROVIDER=local

# Optional PostgreSQL + pgvector
RAG_DATABASE_DSN=postgresql://127.0.0.1:5432/enterprise_rag_mvp

# Optional embedding and reranker services
EMBEDDING_SERVICE_URL=http://127.0.0.1:8001
RERANKER_SERVICE_URL=
RERANKER_PROVIDER=external_cross_encoder

# Optional bad-case feedback output. data/ is ignored by git.
RAG_BAD_CASE_PATH=data/bad_cases.jsonl

# Optional custom business policy importer.
# Keep the real value only in your shell or deployment secret store.
COMPANY_AUTH_COOKIE=<put-your-auth-cookie-here>
COMPANY_POLICY_BASE_URL=https://your-internal-policy-host.example
