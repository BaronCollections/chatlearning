# Copy to .env and replace all CHANGEME values before starting Langfuse.
LANGFUSE_PUBLIC_URL=http://YOUR-INTRANET-IP:3030
LANGFUSE_PORT=3030
LANGFUSE_BIND=0.0.0.0
NEXTAUTH_URL=http://YOUR-INTRANET-IP:3030
NEXTAUTH_SECRET=CHANGEME_32_BYTE_SECRET
SALT=CHANGEME_SALT
ENCRYPTION_KEY=CHANGEME_64_HEX_CHARS
POSTGRES_PASSWORD=CHANGEME_POSTGRES_PASSWORD
CLICKHOUSE_PASSWORD=CHANGEME_CLICKHOUSE_PASSWORD
REDIS_AUTH=CHANGEME_REDIS_PASSWORD
MINIO_ROOT_USER=langfuse-minio
MINIO_ROOT_PASSWORD=CHANGEME_MINIO_PASSWORD
LANGFUSE_INIT_ORG_ID=enterprise-rag-org
LANGFUSE_INIT_ORG_NAME="Enterprise RAG"
LANGFUSE_INIT_PROJECT_ID=enterprise-rag
LANGFUSE_INIT_PROJECT_NAME="Enterprise RAG Trace"
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-CHANGEME
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-CHANGEME
LANGFUSE_INIT_USER_EMAIL=admin@enterprise-rag.local
LANGFUSE_INIT_USER_NAME="Enterprise RAG Admin"
LANGFUSE_INIT_USER_PASSWORD=CHANGEME_ADMIN_PASSWORD
